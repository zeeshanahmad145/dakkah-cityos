{
    "version": 2,
    "buildCommand": "cd apps/backend && npx medusa db:migrate && cd ../.. && turbo run build --filter=backend",
    "outputDirectory": "apps/backend/.medusa/server",
    "installCommand": "pnpm install --no-frozen-lockfile",
    "framework": null,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.js"
        }
    ]
}