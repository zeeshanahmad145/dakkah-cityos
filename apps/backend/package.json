{
  "name": "backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "dev:tee": "medusa develop 2>&1 | tee -a ../backend.log",
    "worker": "npx tsx src/temporal/worker-standalone.ts",
    "worker:financial": "cross-env TEMPORAL_TASK_QUEUE=uce-commerce-financial npx tsx src/temporal/worker-standalone.ts",
    "worker:dispatch": "cross-env TEMPORAL_TASK_QUEUE=uce-commerce-dispatch npx tsx src/temporal/worker-standalone.ts",
    "worker:recurring": "cross-env TEMPORAL_TASK_QUEUE=uce-commerce-recurring npx tsx src/temporal/worker-standalone.ts",
    "worker:fulfilment": "cross-env TEMPORAL_TASK_QUEUE=uce-commerce-fulfilment npx tsx src/temporal/worker-standalone.ts",
    "worker:all": "npx concurrently -n financial,dispatch,recurring,fulfilment -c blue,green,yellow,magenta \"pnpm worker:financial\" \"pnpm worker:dispatch\" \"pnpm worker:recurring\" \"pnpm worker:fulfilment\"",
    "test": "npx cross-env TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:integration:http": "npx cross-env TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "npx cross-env TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:unit": "npx cross-env TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:integration:services": "npx cross-env TEST_TYPE=integration:services NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:e2e": "npx cross-env TEST_TYPE=e2e NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:e2e:custom": "npx cross-env TEST_TYPE=e2e:custom vitest run tests/integration/*.spec.ts --passWithNoTests=false",
    "seed:master": "medusa exec ./src/scripts/seed-master.ts",
    "storage:scaffold": "npx tsx src/scripts/storage-scaffold.ts",
    "storage:scaffold:fix": "npx tsx src/scripts/storage-scaffold.ts --fix"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/admin-shared": "2.13.1",
    "@medusajs/cache-redis": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/dashboard": "2.13.1",
    "@medusajs/draft-order": "2.13.1",
    "@medusajs/event-bus-redis": "2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/icons": "2.13.1",
    "@medusajs/js-sdk": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@medusajs/types": "2.13.1",
    "@medusajs/ui": "4.1.1",
    "@sentry/node": "^10.39.0",
    "@tanstack/react-query": "5.64.2",
    "@temporalio/client": "^1.14.1",
    "@temporalio/worker": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "@vercel/blob": "^2.3.0",
    "crypto-js": "^4.2.0",
    "meilisearch": "^0.55.0",
    "node-cron": "^4.2.1",
    "react-router-dom": "6.30.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.1",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "29.5.13",
    "@types/node": "20.19.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "axios": "^1.13.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "ioredis": "^5.9.1",
    "jest": "29.7.0",
    "logform": "^2.7.0",
    "luxon": "^3.7.2",
    "meilisearch": "^0.55.0",
    "prom-client": "^15.1.3",
    "prop-types": "15.8.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "stripe": "^20.3.1",
    "ts-node": "10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "vite": "7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4",
    "winston": "^3.19.0",
    "yalc": "1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}