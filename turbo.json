        "MINIO_ROOT_USER",
        "MINIO_ROOT_PASSWORD",
        "MINIO_BUCKET",
        "MINIO_AISTOR_KEY",
        "PORT",
        "PAYLOAD_PUBLIC_SERVER_URL",
        "SEED_DB",
        "FIREBASE_SERVICE_ACCOUNT_JSON",
        "FIREBASE_PROJECT_ID",
        "GOOGLE_APPLICATION_CREDENTIALS",
        "cms_blob_READ_WRITE_TOKEN",
        "commerce_db_NEON_PROJECT_ID",
        "STOREFRONT_PORT",
        "STOREFRONT_URL",
        "VERCEL",
        "NEON_DATABASE_URL",
        "SENTRY_DSN",
        "JWT_SECRET",
        "COOKIE_SECRET",
        "MEDUSA_PUBLISHABLE_KEY",
        "VITE_MEDUSA_BACKEND_URL",
        "VITE_MEDUSA_PUBLISHABLE_KEY"
